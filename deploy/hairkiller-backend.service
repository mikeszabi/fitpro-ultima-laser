[Unit]
Description=Hairkiller Backend
After=network.target

[Service]
Type=simple
User=digdeep
WorkingDirectory=/home/digdeep/Projects/hairkiller

ExecStart=/home/digdeep/Projects/hairkiller/yolo_venv/bin/uvicorn backend.hk_backend_app:app --host 127.0.0.1 --port 8000

StandardOutput=append:/var/log/hairkiller/backend.log
StandardError=append:/var/log/hairkiller/backend-error.log
